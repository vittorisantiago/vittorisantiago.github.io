---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import AboutSection from '../components/AboutSection.jsx';
import ProjectsSection from '../components/ProjectsSection.jsx';
import ContactSection from '../components/ContactSection.jsx';
---

<Layout title="Santiago Vittori | Portfolio">
    <Navbar client:load />

    <main class="relative flex min-h-screen flex-col items-center pt-32 px-4 pb-6">
        
        <section id="home" class="flex flex-col items-center text-center max-w-3xl space-y-8 scroll-mt-32">

            <h1 class="text-6xl md:text-8xl font-bold tracking-tighter leading-[1.05] pb-2 text-transparent bg-clip-text bg-gradient-to-b from-white via-red-200 to-red-500/30">
                Santiago Vittori
            </h1>
            
            <p class="relative max-w-2xl px-6 py-5 text-base md:text-lg leading-relaxed text-neutral-300/90 bg-red-950/10 border border-red-900/30 rounded-3xl shadow-[0_20px_60px_-25px_rgba(220,38,38,0.25)] backdrop-blur">
                <span class="text-xs font-semibold tracking-[0.35em] text-red-300/80 uppercase">Especialista en Seguridad</span>
                <span class="block mt-3 text-xl md:text-2xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-red-300 via-orange-300 to-red-400">Penetration Testing & Ciberseguridad Ofensiva</span>
                <span class="block mt-2 text-white/80">Me especializo en auditorías de seguridad y análisis de vulnerabilidades. Detecto fallos desde la arquitectura hasta el código.</span>
                <span class="block mt-1 text-white/80">Metodología OWASP, automatización mediante Python y pensamiento lateral para exponer riesgos.</span>
            </p>

            <div class="h-32"></div> </section>

        <AboutSection client:load />

        <ProjectsSection client:load />

        <ContactSection client:load />

    </main>
</Layout>
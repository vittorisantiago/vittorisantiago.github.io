---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import AboutSection from '../components/AboutSection.jsx';
import ProjectsSection from '../components/ProjectsSection.jsx';
import ContactSection from '../components/ContactSection.jsx';
---

<Layout title="Santiago Vittori | Portfolio">
    <Navbar client:load />

    <main class="relative flex min-h-screen flex-col items-center pt-32 px-4 pb-6">
        
        <section id="home" class="flex flex-col items-center text-center max-w-3xl space-y-8 scroll-mt-32">
            
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-green-500/20 bg-green-500/10 text-green-400 text-xs font-medium animate-fade-in-up">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                </span>
                Disponible para nuevos proyectos
            </div>

            <h1 class="text-6xl md:text-8xl font-bold tracking-tighter leading-[1.05] pb-2 text-transparent bg-clip-text bg-gradient-to-b from-white via-white to-white/40">
                Santiago Vittori
            </h1>
            
            <p class="relative max-w-2xl px-6 py-5 text-base md:text-lg leading-relaxed text-neutral-300/90 bg-white/5 border border-white/10 rounded-3xl shadow-[0_20px_60px_-25px_rgba(16,185,129,0.45)] backdrop-blur">
                <span class="text-xs font-semibold tracking-[0.35em] text-emerald-200/80 uppercase">Perfil profesional</span>
                <span class="block mt-3 text-xl md:text-2xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-emerald-200 via-green-200 to-cyan-200">Ingeniero en Sistemas enfocado en crear soluciones de valor real.</span>
                <span class="block mt-2">Combino desarrollo Full Stack, análisis de datos y herramientas de IA para resolver problemas y automatizar procesos.</span>
                <span class="block mt-1 text-white/80">Visión analítica, ejecución práctica y adaptabilidad constante.</span>
            </p>

            <div class="h-32"></div> </section>

        <AboutSection client:load />

        <ProjectsSection client:load />

        <ContactSection client:load />

    </main>
</Layout>